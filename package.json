{
  "name": "aboutyji",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "node scripts/patch-astro-deps.mjs",
    "predev": "node scripts/patch-astro-deps.mjs && node scripts/sync-legacy.mjs",
    "dev": "astro dev --host localhost",
    "prebuild": "node scripts/patch-astro-deps.mjs && node scripts/sync-legacy.mjs",
    "build": "astro build",
    "preview": "astro preview --host localhost",
    "check": "astro check",
    "lint": "astro check",
    "new:note": "node scripts/new-content.mjs note",
    "new:essay": "node scripts/new-content.mjs essay"
  },
  "dependencies": {
    "@astrojs/check": "0.9.4",
    "@astrojs/mdx": "4.0.8",
    "astro": "5.1.1",
    "katex": "0.16.11",
    "rehype-katex": "7.0.1",
    "remark-math": "6.0.0",
    "typescript": "5.7.2"
  },
  "devDependencies": {}
}
