---
import { getCollection, render } from 'astro:content';
import LegacyLayout from '../../layouts/LegacyLayout.astro';
import PageHero from '../../components/PageHero.astro';

export async function getStaticPaths() {
  const showDrafts = import.meta.env.DEV || import.meta.env.PUBLIC_SHOW_DRAFTS === 'true';
  const essays = await getCollection('essays');
  return essays
    .filter((essay) => showDrafts || !essay.data.draft)
    .map((essay) => ({
      params: { slug: essay.slug ?? essay.data.slug ?? essay.id.replace(/\.mdx$/, '') },
      props: { essay }
    }));
}

const { essay } = Astro.props;
const { Content } = await render(essay);
---

<LegacyLayout title={`${essay.data.title} - Essays - Jonginn Yun`}>
  <PageHero title={essay.data.title} subtitle={essay.data.summary} />
  <main id="main">
    <section class="v1-section">
      <div class="container">
        <article class="v1-prose">
          {essay.data.draft && <p><span class="draft-badge">draft</span></p>}
          <Content />
        </article>
      </div>
    </section>
  </main>
</LegacyLayout>
