---
import { existsSync, readFileSync } from 'node:fs';
import { join } from 'node:path';
import { getCollection } from 'astro:content';
import { render } from 'astro:content';
import LegacyLayout from '../../layouts/LegacyLayout.astro';
import PageHero from '../../components/PageHero.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.slug ?? project.data.slug ?? project.id.replace(/\.mdx$/, '') },
    props: { project }
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);

function rootPathFromLegacy(project: { data: { legacy_file?: string; legacy_url?: string } }) {
  if (project.data.legacy_file) return project.data.legacy_file;
  return project.data.legacy_url?.replace(/^\/legacy\//, '') ?? '';
}

function normalizeLegacyPaths(html: string) {
  return html
    .replace(/(src|href)="assets\//g, '$1="/assets/')
    .replace(/(src|href)="\.\.\/assets\//g, '$1="/assets/')
    .replace(/(src|href)="\.\.\/\.\.\/assets\//g, '$1="/assets/')
    .replace(/href="index\.html#/g, 'href="/#')
    .replace(/href="index\.html"/g, 'href="/"');
}

function legacyProjectSection(project: { data: { legacy_file?: string; legacy_url?: string } }) {
  const legacyPath = rootPathFromLegacy(project);
  if (!legacyPath) return '';

  const absolutePath = join(process.cwd(), legacyPath);
  if (!existsSync(absolutePath)) return '';

  const html = readFileSync(absolutePath, 'utf8');
  const section = html.match(/<section[^>]*class="portfolio-details"[^>]*>[\s\S]*?<\/section>/i)?.[0];
  return section ? normalizeLegacyPaths(section) : '';
}

const legacyDetails = legacyProjectSection(project);
const projectBreadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Projects', href: '/projects/' },
  { label: project.data.title }
];
---

<LegacyLayout title={`${project.data.title} - Jonginn Yun`}>
  <PageHero title={project.data.title} background={project.data.image} breadcrumbs={projectBreadcrumbs} />
  <main id="main">
    <section class="portfolio-details">
      <div class="container">
        <div class="v1-project-detail v1-prose v1-prose-wide">
          <div class="v1-project-kicker">
            <span>{project.data.category}</span>
            {project.data.period && <span>{project.data.period}</span>}
            {project.data.role && <span>{project.data.role}</span>}
          </div>
          {project.data.summary && <p class="v1-project-summary">{project.data.summary}</p>}
          <Content />
          {legacyDetails && (
            <div class="v1-project-supplement">
              <Fragment set:html={legacyDetails} />
            </div>
          )}
        </div>
      </div>
    </section>
  </main>
</LegacyLayout>
