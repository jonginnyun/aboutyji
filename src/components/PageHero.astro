---
interface Props {
  title: string;
  subtitle?: string;
  background?: string;
  breadcrumbs?: Array<{
    label: string;
    href?: string;
  }>;
}

const {
  title,
  subtitle,
  background = '/assets/img/overlay-bg.png',
  breadcrumbs = [
    { label: 'Home', href: '/' },
    { label: title }
  ]
} = Astro.props;
---

<div class="hero hero-single route bg-image v1-page-hero" style={`background-image: url(${background})`}>
  <div class="overlay-mf"></div>
  <div class="hero-content display-table">
    <div class="table-cell">
      <div class="container">
        <h2 class="hero-title mb-4">{title}</h2>
        {subtitle && <p class="hero-subtitle v1-hero-subtitle">{subtitle}</p>}
        <ol class="breadcrumb d-flex justify-content-center">
          {breadcrumbs.map((item, index) => (
            <li class:list={['breadcrumb-item', index === breadcrumbs.length - 1 && 'active']}>
              {item.href && index !== breadcrumbs.length - 1 ? <a href={item.href}>{item.label}</a> : item.label}
            </li>
          ))}
        </ol>
      </div>
    </div>
  </div>
</div>
